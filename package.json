{
  "name": "ts-lib",
  "version": "0.1.0",
  "description": "A TypeScript library template compatible with Node.js and Bun",
  "license": "UNLICENSED",
  "packageManager": "bun@1.3.14",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "check": "biome check . && bun run typecheck",
    "fix": "biome check --write .",
    "test": "bun test",
    "test:unit": "bun test src",
    "test:integration": "bun test tests",
    "test:node": "node --test tests-node/*.test.mjs",
    "attw": "attw --pack --ignore-rules cjs-resolves-to-esm",
    "publint": "publint",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@biomejs/biome": "2.4.15",
    "@types/bun": "1.3.14",
    "publint": "0.3.21",
    "typescript": "6.0.3"
  }
}
